<section class="style-app" id="style-app" aria-label="风格">
    <div class="style-top">
        <div class="style-cover interactive" data-style-upload="desktopWallpaper" role="button" tabindex="0" aria-label="更换桌面壁纸"></div>
        <div class="style-identity">
            <button class="style-title interactive" id="style-title" type="button" aria-label="返回主屏">STYLE</button>
            <div class="style-name">风格</div>
            <div class="style-note">Visual entry framework</div>
        </div>
    </div>

    <main class="style-main-view" id="style-main-view">
        <ol class="style-menu" aria-label="风格功能入口">
            <li class="style-menu-item interactive" role="button" tabindex="0" data-style-entry="theme">
                <span class="style-index">01</span>
                <span class="style-copy">
                    <span class="style-label">主题与配色</span>
                    <span class="style-subtitle">Theme & Palette</span>
                </span>
            </li>
            <li class="style-menu-item interactive" role="button" tabindex="0" data-style-entry="wallpaper">
                <span class="style-index">02</span>
                <span class="style-copy">
                    <span class="style-label">壁纸与背景</span>
                    <span class="style-subtitle">Wallpaper & Background</span>
                </span>
            </li>
            <li class="style-menu-item interactive" role="button" tabindex="0" data-style-entry="icons">
                <span class="style-index">03</span>
                <span class="style-copy">
                    <span class="style-label">图标与组件</span>
                    <span class="style-subtitle">Icons & Components</span>
                </span>
            </li>
            <li class="style-menu-item interactive" role="button" tabindex="0" data-style-entry="typography">
                <span class="style-index">04</span>
                <span class="style-copy">
                    <span class="style-label">字体与页面</span>
                    <span class="style-subtitle">Typography & Page</span>
                </span>
            </li>
            <li class="style-menu-item interactive" role="button" tabindex="0" data-style-entry="screen">
                <span class="style-index">05</span>
                <span class="style-copy">
                    <span class="style-label">屏幕与预设</span>
                    <span class="style-subtitle">Screens & Presets</span>
                </span>
            </li>
        </ol>
    </main>

    <section class="style-subpage" id="style-section-theme" data-style-section="theme" hidden>
        <div class="style-subpage-bar">
            <span class="style-kicker">01 / THEME</span>
            <button class="style-subpage-title interactive" type="button" data-style-back>主题与配色</button>
            <span class="style-status-pill" id="style-theme-status">ROSE GREY</span>
        </div>
        <div class="style-theme-grid" aria-label="主题色">
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="rose"><span class="style-swatch-row"><span style="background:#d9b7c0"></span><span style="background:#f6eef1"></span><span style="background:#6b4d58"></span></span><span class="style-theme-name">玫瑰灰</span><span class="style-theme-hex">#d9b7c0 / #6b4d58</span></button>
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="sage"><span class="style-swatch-row"><span style="background:#b7c9bd"></span><span style="background:#f0f5ef"></span><span style="background:#3e5a48"></span></span><span class="style-theme-name">鼠尾草</span><span class="style-theme-hex">#b7c9bd / #3e5a48</span></button>
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="lake"><span class="style-swatch-row"><span style="background:#a9c8d8"></span><span style="background:#edf6f8"></span><span style="background:#31586a"></span></span><span class="style-theme-name">湖雾蓝</span><span class="style-theme-hex">#a9c8d8 / #31586a</span></button>
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="mauve"><span class="style-swatch-row"><span style="background:#c9b5d9"></span><span style="background:#f5eff8"></span><span style="background:#614a75"></span></span><span class="style-theme-name">雾紫藤</span><span class="style-theme-hex">#c9b5d9 / #614a75</span></button>
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="clay"><span class="style-swatch-row"><span style="background:#d9b08f"></span><span style="background:#fbf0e7"></span><span style="background:#6b4933"></span></span><span class="style-theme-name">陶土杏</span><span class="style-theme-hex">#d9b08f / #6b4933</span></button>
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="citrus"><span class="style-swatch-row"><span style="background:#d7cf82"></span><span style="background:#faf7df"></span><span style="background:#5f5a22"></span></span><span class="style-theme-name">柑橄榄</span><span class="style-theme-hex">#d7cf82 / #5f5a22</span></button>
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="coral"><span class="style-swatch-row"><span style="background:#e4a39c"></span><span style="background:#fff0ed"></span><span style="background:#7b3d38"></span></span><span class="style-theme-name">珊瑚雾</span><span class="style-theme-hex">#e4a39c / #7b3d38</span></button>
            <button class="style-theme-card interactive" type="button" data-style-choice data-style-group="theme" data-style-value="noir"><span class="style-swatch-row"><span style="background:#1c2026"></span><span style="background:#2f3944"></span><span style="background:#d6c59d"></span></span><span class="style-theme-name">夜幕金</span><span class="style-theme-hex">#1c2026 / #d6c59d</span></button>
        </div>
    </section>

    <section class="style-subpage" id="style-section-wallpaper" data-style-section="wallpaper" hidden>
        <div class="style-subpage-bar">
            <span class="style-kicker">02 / WALLPAPER</span>
            <button class="style-subpage-title interactive" type="button" data-style-back>壁纸与背景</button>
        </div>
        <div class="style-phone-grid">
            <article class="style-phone-card">
                <div class="style-preview-shell">
                    <div class="style-phone-preview interactive" data-style-preview="lock" data-style-upload="lockWallpaper" role="button" tabindex="0" aria-label="更换锁屏壁纸">
                        <div class="style-phone-layout">
                            <div class="style-phone-island"></div>
                            <div class="style-phone-clock">09:41</div>
                            <div class="style-phone-date">4月23日 星期四</div>
                            <div class="style-phone-dots"><span></span><span></span><span></span><span></span></div>
                        </div>
                    </div>
                </div>
                <div class="style-phone-meta"><span>锁屏壁纸</span><button class="style-mini-button danger interactive" type="button" data-style-reset-wallpaper="lockWallpaper">重置</button></div>
            </article>
            <article class="style-phone-card">
                <div class="style-preview-shell">
                    <div class="style-phone-preview interactive" data-style-preview="desktop" data-style-upload="desktopWallpaper" role="button" tabindex="0" aria-label="更换桌面壁纸">
                        <div class="style-phone-layout">
                            <div class="style-phone-island"></div>
                            <div class="style-phone-apps"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
                            <div class="style-phone-dock"><span></span><span></span><span></span><span></span></div>
                        </div>
                    </div>
                </div>
                <div class="style-phone-meta"><span>桌面壁纸</span><button class="style-mini-button danger interactive" type="button" data-style-reset-wallpaper="desktopWallpaper">重置</button></div>
            </article>
        </div>
        <div class="style-wallpaper-palette" aria-label="壁纸色阶"><button class="style-wallpaper-chip interactive" type="button" data-style-choice data-style-group="wallpaper" data-style-value="theme">主题</button><button class="style-wallpaper-chip interactive" type="button" data-style-choice data-style-group="wallpaper" data-style-value="silk">绸雾</button><button class="style-wallpaper-chip interactive" type="button" data-style-choice data-style-group="wallpaper" data-style-value="paper">纸感</button><button class="style-wallpaper-chip interactive" type="button" data-style-choice data-style-group="wallpaper" data-style-value="glass">玻璃</button></div>
    </section>

    <section class="style-subpage" id="style-section-icons" data-style-section="icons" hidden>
        <div class="style-subpage-bar">
            <span class="style-kicker">03 / ICONS</span>
            <button class="style-subpage-title interactive" type="button" data-style-back>图标与组件</button>
            <button class="style-icon-action interactive" id="style-reset-icon-cover" type="button" aria-label="重置图标封面" title="重置图标封面"><svg viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v5M14 11v5"/></svg></button>
        </div>
        <div class="style-control-grid">
            <div class="style-control-block"><span class="style-control-label">图标样式</span><div class="style-segmented" aria-label="图标样式"><button class="interactive" type="button" data-style-choice data-style-group="iconStyle" data-style-value="line">线性</button><button class="interactive" type="button" data-style-choice data-style-group="iconStyle" data-style-value="soft">柔光</button><button class="interactive" type="button" data-style-choice data-style-group="iconStyle" data-style-value="filled">填充</button></div></div>
            <label class="style-control-block"><span class="style-control-label">组件圆角 <output id="style-radius-value">28px</output></span><input class="style-range" id="style-radius-scale" type="range" min="10" max="36" step="1" value="28"></label>
            <label class="style-control-block"><span class="style-control-label">应用圆角 <output id="style-app-radius-value">20px</output></span><input class="style-range" id="style-app-radius-scale" type="range" min="8" max="28" step="1" value="20"></label>
            <label class="style-control-block"><span class="style-control-label">应用名颜色</span><input class="style-color-input" id="style-app-name-color" type="color" value="#2b2b30"></label>
            <div class="style-control-block style-control-wide style-app-cover-manager">
                <div class="style-cover-manager-head compact">
                    <span class="style-control-label">应用图标封面</span>
                    <div class="style-cover-manager-actions">
                        <button class="style-mini-button interactive" id="style-replace-all-app-covers" type="button">全部更换</button>
                        <button class="style-mini-button danger interactive" id="style-reset-all-app-covers" type="button">全部重置</button>
                    </div>
                </div>
                <div class="style-app-cover-list" id="style-app-cover-list"></div>
            </div>
        </div>
        <section class="style-cover-manager" aria-label="桌面封面">
            <div class="style-cover-manager-head">
                <div>
                    <span class="style-control-label">桌面图片位</span>
                    <p>封面、头像和图片组件都可以在这里独立处理。</p>
                </div>
                <div class="style-cover-manager-actions">
                    <button class="style-mini-button interactive" id="style-replace-all-covers" type="button">全部更换</button>
                    <button class="style-mini-button danger interactive" id="style-reset-all-covers" type="button">全部重置</button>
                </div>
            </div>
            <div class="style-cover-list" id="style-desktop-cover-list"></div>
        </section>
    </section>

    <section class="style-subpage" id="style-section-typography" data-style-section="typography" hidden>
        <div class="style-subpage-bar">
            <span class="style-kicker">04 / PAGE</span>
            <button class="style-subpage-title interactive" type="button" data-style-back>字体与页面</button>
            <span class="style-status-pill" id="style-scale-status">16px / 100%</span>
        </div>
        <div class="style-control-grid style-typography-grid">
            <div class="style-control-block style-control-wide">
                <span class="style-control-label">全局字体 <output id="style-font-family-value">心结</output></span>
                <div class="style-font-grid" id="style-font-grid"></div>
            </div>
            <label class="style-control-block"><span class="style-control-label">字体大小 <output id="style-font-size-value">16px</output></span><input class="style-range" id="style-font-size-scale" type="range" min="12" max="24" step="1" value="16"></label>
            <label class="style-control-block"><span class="style-control-label">字体粗细 <output id="style-font-weight-value">400</output></span><input class="style-range" id="style-font-weight" type="range" min="300" max="700" step="50" value="400"></label>
            <label class="style-control-block style-control-wide"><span class="style-control-label">全局 UI 缩放 <output id="style-ui-scale-value">100%</output></span><input class="style-range" id="style-ui-scale" type="range" min="90" max="110" step="1" value="100"></label>
            <div class="style-control-block style-control-wide" id="rinno-style-top-chrome-controls">
                <span class="style-control-label">页面顶部</span>
                <div class="style-toggle-list" aria-label="页面顶部显示">
                    <button class="style-toggle-row interactive" type="button" data-style-hide="status-bar" aria-pressed="false">
                        <span class="style-toggle-knob" aria-hidden="true"></span>
                        <span class="style-toggle-copy"><strong>隐藏状态栏</strong><small>时间、信号与电量</small></span>
                    </button>
                    <button class="style-toggle-row interactive" type="button" data-style-hide="dynamic-island" aria-pressed="false">
                        <span class="style-toggle-knob" aria-hidden="true"></span>
                        <span class="style-toggle-copy"><strong>隐藏灵动岛</strong><small>顶部黑色胶囊</small></span>
                    </button>
                </div>
            </div>
            <div class="style-control-block style-control-wide style-font-custom-block">
                <span class="style-control-label">添加自定义字体 <output>本地文件 / URL</output></span>
                <div class="style-font-input-grid">
                    <input class="style-text-input" id="style-font-custom-name" type="text" placeholder="字体名称（可选）">
                    <input class="style-text-input" id="style-font-custom-url" type="url" placeholder="https://example.com/font.ttf">
                </div>
                <div class="style-font-action-row">
                    <button class="style-mini-button interactive" id="style-font-upload-trigger" type="button">上传本地字体</button>
                    <button class="style-mini-button interactive" id="style-font-url-save" type="button">添加 URL 字体</button>
                </div>
                <p class="style-inline-note">支持 ttf / otf / woff / woff2，添加后会自动出现在上面的展开字体卡片里。</p>
            </div>
        </div>
    </section>

    <section class="style-subpage" id="style-section-screen" data-style-section="screen" hidden>
        <div class="style-subpage-bar">
            <span class="style-kicker">05 / CSS</span>
            <button class="style-subpage-title interactive" type="button" data-style-back>屏幕与预设</button>
            <button class="style-icon-action interactive" id="style-reset-css" type="button" aria-label="重置 CSS 模板" title="重置 CSS 模板"><svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 0 1 15.5-6.2"/><path d="M21 12a9 9 0 0 1-15.5 6.2"/><path d="M18 6h3V3"/><path d="M6 18H3v3"/></svg></button>
        </div>
        <textarea class="style-code-editor" id="style-custom-css" spellcheck="false"></textarea>
        <div class="style-preset-row" aria-label="页面预设"><button class="style-preset-chip interactive" type="button" data-style-choice data-style-group="pagePreset" data-style-value="editorial">杂志</button><button class="style-preset-chip interactive" type="button" data-style-choice data-style-group="pagePreset" data-style-value="compact">紧凑</button><button class="style-preset-chip interactive" type="button" data-style-choice data-style-group="pagePreset" data-style-value="airy">留白</button></div>
    </section>

    <input id="style-lock-wallpaper-input" type="file" accept="image/*" hidden>
    <input id="style-desktop-wallpaper-input" type="file" accept="image/*" hidden>
    <input id="style-app-icon-cover-input" type="file" accept=".png,.jpg,.jpeg,.gif,image/png,image/jpeg,image/gif" hidden>
    <input id="style-desktop-cover-input" type="file" accept="image/*" hidden>
    <input id="style-font-file-input" type="file" accept=".ttf,.otf,.woff,.woff2,font/ttf,font/otf,font/woff,font/woff2" hidden>
</section>

