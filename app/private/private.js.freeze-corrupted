            event.preventDefault();
            event.stopPropagation();
            hidePrivateContactChatActionMenu();
            return;
        }

        if (event.pointerType === 'mouse') return;

        privateContactChatMenuSwipePointerId = event.pointerId;
        privateContactChatMenuSwipeStartX = Number(event.clientX) || 0;
        privateContactChatMenuSwipeStartY = Number(event.clientY) || 0;
