async function requestPrivateContactChatReply(contact, thread) {



    const chat = await loadPrivateContactApiSettings();



    const endpoint = String(chat?.endpoint || '').trim();



    const model = String(chat?.model || '').trim();



    if (!endpoint || !model) {



        throw new Error('');



    }



    const headers = {



        'Content-Type': 'application/json',



        Accept: 'application/json'



    };



    if (chat.apiKey) headers.Authorization = `Bearer ${chat.apiKey}`;



    const contextRounds = Math.max(0, Math.min(40, Number(chat?.contextRounds) || 20));



    const history = normalizePrivateThreads([thread])[0]?.messages || [];



    const historyMessages = history



        .filter(message => ['user', 'assistant'].includes(String(message.role || '')));



    let contextMessages = (contextRounds > 0



        ? historyMessages.slice(-(contextRounds * 2))



        : historyMessages.slice(-1))



        .map(message => ({



            role: message.role,



            content: message.quote



                ? `鍥炲 ${message.quote.senderName || ''}锛?{trimPrivateContactChatSnippet(message.quote.content, 80)}
${message.content}`



                : message.content



        }));



    const contextWindow = contextRounds > 0



        ? Math.max(contextRounds * 3, contextRounds * 2 + 2)



        : 3;



    contextMessages = history



        .slice(-contextWindow)



        .map(createPrivateContactChatApiContextMessage)



        .filter(Boolean);



    const safeTemperature = Number.isFinite(Number(chat?.temperature))



        ? Number(chat.temperature)



        : 0.7;



    const promptContext = await buildPrivateContactChatPromptContext(



        contact,



        chat,



        historyMessages,



        contextMessages,



        contextRounds



    );



    privateContactChatAbortController = new AbortController();



    const response = await fetch(buildPrivateContactChatEndpoint(endpoint), {



        method: 'POST',



        headers,



        signal: privateContactChatAbortController.signal,



        body: JSON.stringify({



            model,



            temperature: safeTemperature,



            messages: [



                { role: 'system', content: buildPrivateContactChatSystemPrompt(contact, promptContext) },



                ...contextMessages



            ]



        })



    });



    if (!response.ok) {



        throw new Error(`鑱婂ぉ鍙戦€佸け璐ワ紙${response.status}锛塦);



    }



    const payload = await response.json();



    const text = extractPrivateContactGeneratedText(payload);



    const replies = parsePrivateContactChatReplyTexts(text);



    if (!replies.length) {



        throw new Error('');



    }



    return replies;



}



