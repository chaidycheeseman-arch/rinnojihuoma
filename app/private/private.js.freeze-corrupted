function positionPrivateContactChatActionMenu(bubble) {



    const menu = ensurePrivateContactChatActionMenu();



    const panel = document.getElementById('private-contact-chat-action-menu-panel');



    if (!menu || !panel || !(bubble instanceof Element)) return;



    const bubbleRect = bubble.getBoundingClientRect();



    const panelRect = panel.getBoundingClientRect();



    const viewportWidth = window.innerWidth;



    const viewportHeight = window.innerHeight;



    let left = bubbleRect.left + (bubbleRect.width / 2) - (panelRect.width / 2);



    let align = 'center';



    if (left < 12) {



        left = 12;



        align = 'left';



    }



    if (left + panelRect.width > viewportWidth - 12) {



        left = Math.max(12, viewportWidth - panelRect.width - 12);



        align = 'right';



    }



    let top = bubbleRect.top - panelRect.height - 16;



    if (top < 84) top = Math.min(viewportHeight - panelRect.height - 12, bubbleRect.bottom + 12);



    panel.style.left = `${Math.max(12, left)}px`;



    panel.style.top = `${Math.max(12, top)}px`;



    menu.dataset.align = align;



    menu.dataset.side = bubble.closest('.private-contact-chat-message')?.classList.contains('is-user') ? 'right' : 'left';



}



