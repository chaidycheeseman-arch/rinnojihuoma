        privateContactChatMenuSwipeAxis = '';
        privateContactChatMenuSwipeSuppressClick = false;
    });

    menu.addEventListener('pointermove', event => {
        const panel = document.getElementById('private-contact-chat-action-menu-panel');
        const track = document.getElementById('private-contact-chat-action-menu-track');
        if (!panel || !track || privateContactChatMenuSwipePointerId !== event.pointerId) return;

        const distanceX = (Number(event.clientX) || 0) - privateContactChatMenuSwipeStartX;
        const distanceY = (Number(event.clientY) || 0) - privateContactChatMenuSwipeStartY;

        if (!privateContactChatMenuSwipeAxis) {
            if (Math.abs(distanceX) < 6 && Math.abs(distanceY) < 6) return;
            privateContactChatMenuSwipeAxis = Math.abs(distanceX) > Math.abs(distanceY) ? 'x' : 'y';
        }

        if (!privateContactChatMenuSwipeDragging) {
            privateContactChatMenuSwipeDragging = true;
            privateContactChatMenuSwipeSuppressClick = true;
        }

        if (event.cancelable) event.preventDefault();
        menu.classList.add('is-dragging');

        if (privateContactChatMenuSwipeAxis === 'x') {
            const maxPageIndex = PRIVATE_CONTACT_CHAT_MENU_PAGES.length - 1;
            let offsetX = distanceX;
            if ((privateContactChatMenuPageIndex === 0 && distanceX > 0) || (privateContactChatMenuPageIndex === maxPageIndex && distanceX < 0)) {
