            if (!id || !type) return null;



            return {



                id,



                type,



                title: String(item?.title || '').trim(),



                subtitle: String(item?.subtitle || '').trim(),



                note: String(item?.note || '').trim(),



                accountId: String(item?.accountId || item?.publicId || '').trim(),



                dossierType: ['char', 'npc'].includes(String(item?.dossierType || '').toLowerCase())



                    ? String(item?.dossierType || '').toLowerCase()



                    : '',



                dossierRecordId: String(item?.dossierRecordId || item?.recordId || '').trim(),



                avatar: String(item?.avatar || '').trim(),



                homepageCover: String(item?.homepageCover || item?.cover || '').trim(),



                ownerId: String(item?.ownerId || item?.owner || '').trim(),



                profileBundle: normalizePrivateContactProfileBundle(item?.profileBundle, {}, id)



                    || migrateLegacyPrivateContactProfileBundle({ ...item, id })



            };



        })



        .filter(Boolean);



    const seen = new Set();



    return normalized.filter(contact => {



        if (seen.has(contact.id)) return false;



        seen.add(contact.id);



        return true;



