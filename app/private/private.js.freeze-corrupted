function parsePrivateContactChatReplyTexts(text) {



    const raw = normalizePrivateContactChatReplyText(text);



    if (!raw) return [];



    const normalizeParsedItems = parsed => {



        const list = Array.isArray(parsed) ? parsed : [parsed];



        return list.map(item => {



            if (typeof item === 'string') {



                const content = normalizePrivateContactChatReplyText(item);



                return content ? { type: 'text', content, quoteText: '' } : null;



            }



            if (!item || typeof item !== 'object') return null;



            const type = String(item.type || '').trim().toLowerCase();



            const content = [



                item.content,



                item.text,



                item.message,



                item.value



            ].map(value => normalizePrivateContactChatReplyText(value)).find(Boolean) || '';



            const quoteText = normalizePrivateContactChatReplyText(



                item.target_text



                || item.target



                || item.reply_to



                || item.reference



                || ''



            );



            if (!type && content) return { type: 'text', content, quoteText: '' };



            if (type === 'text') return content ? { type: 'text', content, quoteText: '' } : null;



            if (type === 'reply') return content ? { type: 'reply', content, quoteText } : null;



            if (type === 'recall_msg') return content ? { type: 'recall_msg', content, quoteText: '' } : null;



            return null;



        }).filter(Boolean);



    };



    const candidates = [raw];



    const arrayStart = raw.indexOf('[');



    const arrayEnd = raw.lastIndexOf(']');



    if (arrayStart >= 0 && arrayEnd > arrayStart) {



        candidates.unshift(raw.slice(arrayStart, arrayEnd + 1));



    }



    const objectStart = raw.indexOf('{');



    const objectEnd = raw.lastIndexOf('}');



    if (objectStart >= 0 && objectEnd > objectStart) {



        candidates.push(raw.slice(objectStart, objectEnd + 1));



    }



    for (const candidate of candidates) {



        try {



            const parsed = JSON.parse(candidate);



            const normalized = normalizeParsedItems(parsed);



            if (normalized.length) return normalized;



        } catch (error) {



            continue;



        }



    }



    return [{ type: 'text', content: raw, quoteText: '' }];



}



