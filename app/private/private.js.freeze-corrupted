function normalizePrivateContactPromptBlock(value, maxLength = 320) {



    return String(value ?? '')



        .replace(/\r/g, '')



        .replace(/[ \t]+\n/g, '\n')



        .replace(/\n[ \t]+/g, '\n')



        .replace(/\n{3,}/g, '\n\n')



        .trim()



        .slice(0, maxLength);



}



function escapePrivateContactPromptTag(value, maxLength = 160) {



    return normalizePrivateContactPromptInline(value, maxLength)



        .replace(/&/g, '&amp;')



        .replace(/</g, '&lt;')



        .replace(/>/g, '&gt;')



        .replace(/"/g, '&quot;');



}



function formatPrivateContactPromptTimestamp(value) {



    const time = Number(value) || 0;



    if (!time) return '';



    try {



        return new Intl.DateTimeFormat('zh-CN', {



            month: 'numeric',



            day: 'numeric',



            hour: 'numeric',



            minute: '2-digit'



        }).format(new Date(time));



    } catch (error) {



        const date = new Date(time);



        if (Number.isNaN(date.getTime())) return '';



        const month = date.getMonth() + 1;



        const day = date.getDate();



        const hour = date.getHours();



        const minute = String(date.getMinutes()).padStart(2, '0');



        return `${month}/${day} ${hour}:${minute}`;



    }



}



