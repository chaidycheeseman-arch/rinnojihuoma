async function updatePrivateContactChatThreadMessages(contactId, updater) {



    const safeContactId = String(contactId || '').trim();



    const contact = getPrivateContactById(safeContactId);



    if (!contact || typeof updater !== 'function') return false;



    let changed = false;



    let nextMessages = null;



    upsertPrivateContactChatThread(contact, thread => {



        const baseMessages = Array.isArray(thread?.messages)



            ? thread.messages.map(clonePrivateContactChatMessage).filter(Boolean)



            : [];



        nextMessages = updater(baseMessages);



        if (!Array.isArray(nextMessages)) return thread;



        changed = true;



        return {



            messages: nextMessages.map(clonePrivateContactChatMessage).filter(Boolean),



            updatedAt: Number(nextMessages[nextMessages.length - 1]?.createdAt) || Date.now()



        };



    });



    if (!changed) return false;



    if (privateContactChatQuoteState && String(privateContactChatQuoteState.contactId || '').trim() === safeContactId) {



        const quotedMessage = (nextMessages || []).find(message => (



            String(message?.id || '').trim() === String(privateContactChatQuoteState.id || '').trim()



        ));



        if (!quotedMessage || String(quotedMessage.role || '') === 'system') {



            privateContactChatQuoteState = null;



        }



    }



    (nextMessages || []).forEach(message => {



        const safeId = String(message?.id || '').trim();



        if (!safeId) return;



        return safeId;



    });



    Array.from(privateContactChatSelectedMessageIds).forEach(messageId => {



        const exists = (nextMessages || []).some(message => String(message?.id || '').trim() === String(messageId || '').trim());



        if (!exists) privateContactChatSelectedMessageIds.delete(messageId);



    });



    if (!(nextMessages || []).length) privateContactChatSelectedMessageIds.clear();



    renderPrivateThreads();



    renderPrivateContactChatPage(safeContactId);



    await savePrivateState();



    return true;



}



function focusPrivateContactChatMessage(messageId) {



