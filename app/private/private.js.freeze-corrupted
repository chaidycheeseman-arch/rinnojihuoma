        panel.style.transition = 'none';
        panel.style.transform = `translate3d(${Math.max(-24, Math.min(24, distanceX * 0.16))}px, ${Math.max(-24, Math.min(60, distanceY * 0.88))}px, 0) scale(${1 - Math.min(0.08, (Math.abs(distanceY) + Math.abs(distanceX) * 0.18) / 520)})`;
        panel.style.opacity = String(Math.max(0.34, 1 - (Math.abs(distanceY) + Math.abs(distanceX) * 0.22) / 172));
        track.style.transition = '';
        track.style.transform = `translate3d(${-privateContactChatMenuPageIndex * 100}%, 0, 0)`;
    }, { passive: false });

    const handleMenuGestureFinish = event => {
        if (privateContactChatMenuSwipePointerId !== event.pointerId) return;

        const distanceX = (Number(event.clientX) || 0) - privateContactChatMenuSwipeStartX;
        const distanceY = (Number(event.clientY) || 0) - privateContactChatMenuSwipeStartY;
        const axis = privateContactChatMenuSwipeAxis;
        const shouldClose = axis === 'y' && privateContactChatMenuSwipeDragging && (
            Math.abs(distanceY) > PRIVATE_CONTACT_CHAT_MENU_CLOSE_SWIPE_DISTANCE ||
            Math.abs(distanceX) > PRIVATE_CONTACT_CHAT_MENU_CLOSE_SWIPE_DISTANCE * 1.2
        );

        let nextPageIndex = privateContactChatMenuPageIndex;
        if (axis === 'x' && privateContactChatMenuSwipeDragging) {
            if (distanceX <= -PRIVATE_CONTACT_CHAT_MENU_PAGE_SWIPE_DISTANCE) nextPageIndex += 1;
            if (distanceX >= PRIVATE_CONTACT_CHAT_MENU_PAGE_SWIPE_DISTANCE) nextPageIndex -= 1;
        }

        nextPageIndex = Math.max(0, Math.min(PRIVATE_CONTACT_CHAT_MENU_PAGES.length - 1, nextPageIndex));
        resetPrivateContactChatActionMenuSwipeState();

        if (shouldClose) {
            hidePrivateContactChatActionMenu();
            return;
        }

        setPrivateContactChatActionMenuPage(nextPageIndex);
    };

    menu.addEventListener('pointerup', handleMenuGestureFinish);
    menu.addEventListener('pointercancel', handleMenuGestureFinish);

    privateApp.appendChild(menu);
    setPrivateContactChatActionMenuPage(0, { instant: true });
    return menu;
}
function setPrivateContactChatActionMenuPage(pageIndex, options = {}) {



    const menu = document.getElementById('private-contact-chat-action-menu');



    const track = document.getElementById('private-contact-chat-action-menu-track');



    if (!menu || !track) return;



    const maxPageIndex = Math.max(0, PRIVATE_CONTACT_CHAT_MENU_PAGES.length - 1);



    privateContactChatMenuPageIndex = Math.max(0, Math.min(maxPageIndex, Number(pageIndex) || 0));



    menu.dataset.page = String(privateContactChatMenuPageIndex);



    if (options.instant) track.style.transition = 'none';



    track.style.transform = `translate3d(${-privateContactChatMenuPageIndex * 100}%, 0, 0)`;



    if (options.instant) {



        requestAnimationFrame(() => {



            track.style.transition = '';



        });



    }



    const prevButton = menu.querySelector('[data-private-contact-chat-action-nav="prev"]');



    const nextButton = menu.querySelector('[data-private-contact-chat-action-nav="next"]');



    if (prevButton) prevButton.hidden = privateContactChatMenuPageIndex <= 0;



    if (nextButton) nextButton.hidden = privateContactChatMenuPageIndex >= maxPageIndex;



    menu.querySelectorAll('[data-private-contact-chat-action-page-dot]').forEach(node => {



        const dotPageIndex = Number(node.getAttribute('data-private-contact-chat-action-page-dot'));



        const isCurrent = dotPageIndex === privateContactChatMenuPageIndex;



        node.classList.toggle('is-current', isCurrent);



        node.setAttribute('aria-selected', isCurrent ? 'true' : 'false');



    });



}



