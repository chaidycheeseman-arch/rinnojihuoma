function bindPrivateContactChatInteractions(page) {



    if (!page || privateContactChatInteractionsBound) return;



    const content = page.querySelector('#private-contact-chat-content');



    const quoteClear = page.querySelector('#private-contact-chat-quote-clear');



    const selectCancel = page.querySelector('#private-contact-chat-select-cancel');



    const selectDelete = page.querySelector('#private-contact-chat-select-delete');



    if (!content) return;



    privateContactChatInteractionsBound = true;



    ensurePrivateContactChatActionMenu();



    ensurePrivateContactChatEditModal();



    ensurePrivateContactChatRecallDetailModal();



    const findBubble = target => target instanceof Element ? target.closest('[data-private-contact-chat-bubble]') : null;



    const cancelPress = () => clearPrivateContactChatMenuTimer();



    content.addEventListener('pointerdown', event => {



        if (privateContactChatMultiSelectMode || event.pointerType === 'mouse') return;



        const bubble = findBubble(event.target);



        if (!bubble) return;



        privateContactChatMenuPressX = Number(event.clientX) || 0;



        privateContactChatMenuPressY = Number(event.clientY) || 0;



        clearPrivateContactChatMenuTimer();



        privateContactChatMenuTimer = window.setTimeout(() => {



            privateContactChatMenuTimer = 0;



            openPrivateContactChatActionMenu(bubble);



            if (navigator.vibrate) navigator.vibrate(18);



        }, PRIVATE_CONTACT_CHAT_LONG_PRESS_MS);



    }, { passive: true });



    content.addEventListener('pointermove', event => {



        if (!privateContactChatMenuTimer) return;



        const distanceX = Math.abs((Number(event.clientX) || 0) - privateContactChatMenuPressX);



        const distanceY = Math.abs((Number(event.clientY) || 0) - privateContactChatMenuPressY);



        if (distanceX > PRIVATE_CONTACT_CHAT_MENU_MOVE_TOLERANCE || distanceY > PRIVATE_CONTACT_CHAT_MENU_MOVE_TOLERANCE) {



            cancelPress();



        }



    }, { passive: true });



    ['pointerup', 'pointercancel', 'pointerleave'].forEach(eventName => {



        content.addEventListener(eventName, cancelPress, { passive: true });



    });



    content.addEventListener('contextmenu', event => {



        const bubble = findBubble(event.target);



        if (!bubble) return;



        event.preventDefault();



        event.stopPropagation();



        openPrivateContactChatActionMenu(bubble);



    });



    content.addEventListener('scroll', () => hidePrivateContactChatActionMenu(), { passive: true });



    content.addEventListener('click', event => {



        const recallButton = event.target.closest('[data-private-contact-chat-recall-detail]');



        if (recallButton) {



            event.preventDefault();



            event.stopPropagation();



            openPrivateContactChatRecallDetail(recallButton.getAttribute('data-private-contact-chat-recall-detail') || '');



            return;



        }



        const quoteBlock = event.target.closest('[data-private-contact-chat-quote-id]');



        if (quoteBlock && !privateContactChatMultiSelectMode) {



            event.preventDefault();



            event.stopPropagation();



            focusPrivateContactChatMessage(quoteBlock.getAttribute('data-private-contact-chat-quote-id') || '');



            return;



        }



        const messageWrap = event.target.closest('[data-private-contact-chat-message-id]');



        if (!messageWrap || !privateContactChatMultiSelectMode) return;



        event.preventDefault();



        event.stopPropagation();



        togglePrivateContactChatSelectedMessage(messageWrap.getAttribute('data-private-contact-chat-message-id') || '');



    });



    quoteClear?.addEventListener('click', event => {



        event.preventDefault();



        event.stopPropagation();



        clearPrivateContactChatQuoteState();



    });



    selectCancel?.addEventListener('click', event => {



        event.preventDefault();



        event.stopPropagation();



        exitPrivateContactChatMultiSelect();



    });



    selectDelete?.addEventListener('click', async event => {



        event.preventDefault();



        event.stopPropagation();



        await deletePrivateContactChatSelectedMessages();



    });



    document.addEventListener('pointerdown', event => {



        const menu = document.getElementById('private-contact-chat-action-menu');



        if (!menu || menu.hidden) return;



        const panel = document.getElementById('private-contact-chat-action-menu-panel');



        if (event.target instanceof Element && ((panel && panel.contains(event.target)) || event.target.closest('[data-private-contact-chat-bubble]'))) return;



        hidePrivateContactChatActionMenu();



    }, true);



    window.addEventListener('resize', () => hidePrivateContactChatActionMenu(), { passive: true });



}



