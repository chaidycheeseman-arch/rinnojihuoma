    const label = record?.type === 'npc' ? 'NPC' : 'CHAR';



    const contactId = getPrivateDossierContactId(record);



    const prompt = [



        `targetType: ${PRIVATE_CONTACT_PROFILE_BUNDLE_TYPE}`,



        `targetId: ${contactId}`,



        `characterType: ${label}`,



        `name: ${record?.name || ''}`,



        `nickname: ${record?.nickname || ''}`,



