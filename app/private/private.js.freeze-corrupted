async function requestPrivateContactChatAssistantReply(contact) {



    if (!PRIVATE_CONTACT_CHAT_AUTOMATED_REPLY_ENABLED) return false;



    if (!contact) return;



    privateContactChatSendingId = contact.id;



    renderPrivateContactChatPage(contact.id);



    try {



        const thread = getPrivateContactChatThread(contact.id) || {



            messages: []



        };



        const replies = await requestPrivateContactChatReply(contact, thread);



        const startedAt = Date.now();



        let deliveredCount = 0;



        let responseQuoteCount = 0;



        let responseRecallCount = 0;



        let workingMessages = Array.isArray(thread.messages)



            ? thread.messages.map(clonePrivateContactChatMessage).filter(Boolean)



            : [];



        for (let index = 0; index < replies.length; index += 1) {



            const reply = replies[index];



            const type = String(reply?.type || (typeof reply === 'string' ? 'text' : '')).trim().toLowerCase() || 'text';



            const content = normalizePrivateContactChatReplyText(



                typeof reply === 'string'



                    ? reply



                    : (reply?.content || '')



            );



            if (!content) continue;



            const messageId = `private-chat-assistant-${startedAt + index}`;



            const createdAt = startedAt + index;



            if (type === 'recall_msg') {



                if (!canPrivateContactChatAssistantRecall(workingMessages, responseRecallCount)) {



                    const fallbackMessage = {



                        id: messageId,



                        role: 'assistant',



                        content,



                        createdAt



                    };



                    const fallbackChanged = await updatePrivateContactChatThreadMessages(contact.id, messages => [...messages, fallbackMessage]);



                    if (fallbackChanged) {



                        workingMessages.push(fallbackMessage);



                        deliveredCount += 1;



                    }



                    continue;



                }



                const temporaryMessage = {



                    id: messageId,



                    role: 'assistant',



                    content,



                    createdAt



                };



                const appended = await updatePrivateContactChatThreadMessages(contact.id, messages => [...messages, temporaryMessage]);



                if (!appended) continue;



                workingMessages.push(temporaryMessage);



                deliveredCount += 1;



                responseRecallCount += 1;



                await new Promise(resolve => window.setTimeout(resolve, PRIVATE_CONTACT_CHAT_ASSISTANT_RECALL_DELAY_MS));



                const recalledMessage = createPrivateContactChatRecalledSystemMessage({



                    id: temporaryMessage.id,



                    actorRole: 'assistant',



                    actorName: String(contact.title || 'TA').trim() || 'TA',



                    originalContent: content,



                    createdAt: temporaryMessage.createdAt,



                    recalledAt: Date.now(),



                    contact



                });



                await updatePrivateContactChatThreadMessages(contact.id, messages => (



                    messages.map(message => (



                        String(message?.id || '').trim() === String(temporaryMessage.id || '').trim()



                            ? recalledMessage



                            : message



                    ))



                ));



                workingMessages = workingMessages.map(message => (



                    String(message?.id || '').trim() === String(temporaryMessage.id || '').trim()



                        ? recalledMessage



                        : message



                ));



                continue;



            }



            let quote = null;



            if (type === 'reply' && canPrivateContactChatAssistantQuote(workingMessages, responseQuoteCount)) {



                quote = findPrivateContactChatQuoteTarget(workingMessages, reply?.quoteText || '', contact);



                if (quote) responseQuoteCount += 1;



            }



            const assistantMessage = {



                id: messageId,



                role: 'assistant',



                content,



                createdAt,



                ...(quote ? { quote } : {})



            };



            const changed = await updatePrivateContactChatThreadMessages(contact.id, messages => [...messages, assistantMessage]);



            if (!changed) continue;



            workingMessages.push(assistantMessage);



            deliveredCount += 1;



        }



        if (!deliveredCount) {



            throw new Error('');



        }



        return;



        const assistantMessages = replies.map((reply, index) => {



            const content = normalizePrivateContactChatReplyText(



                typeof reply === 'string'



                    ? reply



                    : (reply?.content || '')



            );



            if (!content) return null;



            const quote = findPrivateContactChatQuoteTarget(



                Array.isArray(thread.messages) ? thread.messages : [],



                typeof reply === 'object' ? reply?.quoteText : '',



                contact



            );



            return {



                id: `private-chat-assistant-${startedAt + index}`,



                role: 'assistant',



                content,



                createdAt: startedAt + index,



                ...(quote ? { quote } : {})



            };



        }).filter(Boolean);



        if (!assistantMessages.length) {



            throw new Error('');



        }



        const lastAssistantMessage = assistantMessages[assistantMessages.length - 1];



        upsertPrivateContactChatThread(contact, currentThread => ({



            messages: [...(Array.isArray(currentThread.messages) ? currentThread.messages : []), ...assistantMessages],



            updatedAt: lastAssistantMessage?.createdAt || startedAt



        }));



        await savePrivateState();



    } catch (error) {



        if (error?.name !== 'AbortError') {



            const systemMessage = {



                id: `private-chat-system-${Date.now()}`,



                role: 'system',



                content: error?.message || '闁告瑦鍨块埀顑跨閵囨垹鎷归妷顖滅閻犲洭顥撻埣銏ゅ触鎼粹€虫櫃閻犲洦娲忛埀?',



                createdAt: Date.now()



            };



            upsertPrivateContactChatThread(contact, currentThread => ({



                messages: [...(Array.isArray(currentThread.messages) ? currentThread.messages : []), systemMessage],



                updatedAt: systemMessage.createdAt



            }));



            await savePrivateState();



            showPrivateSystemToast(systemMessage.content);



        }



    } finally {



        privateContactChatSendingId = '';



        privateContactChatAbortController = null;



        renderPrivateThreads();



        renderPrivateContactChatPage(contact.id);



        if (document.querySelector('.private-chat-screen')?.getAttribute('data-private-current-tab') === 'contact-chat') {



            document.getElementById('private-contact-chat-input')?.focus();



        }



    }



}



