function normalizePrivateThreads(value) {



    if (!Array.isArray(value)) return [];



    return value



        .slice(0, 50)



        .filter(item => item && typeof item === 'object')



        .map((item, index) => {



            const messages = Array.isArray(item.messages)



                ? item.messages



                    .slice(-80)



                    .map((message, messageIndex) => {



                        if (!message || typeof message !== 'object') return null;



                        const content = String(message.content || '').replace(/\r\n/g, '\n').trim();



                        const role = ['user', 'assistant', 'system'].includes(String(message.role || ''))



                            ? String(message.role)



                            : 'assistant';



                        if (!content) return null;



                        return {



                            ...message,



                            id: String(message.id || `thread-message-${Date.now()}-${index}-${messageIndex}`),



                            role,



                            content,



                            createdAt: Number(message.createdAt) || Date.now()



                        };



                    })



                    .filter(Boolean)



                : [];



            const fallbackUpdatedAt = Number(messages[messages.length - 1]?.createdAt) || 0;



            const contactId = String(item.contactId || item.contact || '').trim();



            return {



                ...item,



                id: String(item.id || contactId || `thread-${Date.now()}-${index}`),



                contactId,



                title: String(item.title || item.name || '').trim(),



                subtitle: String(item.subtitle || item.note || '').trim(),



                avatar: String(item.avatar || '').trim(),



                updatedAt: Number(item.updatedAt) || fallbackUpdatedAt,



                messages



            };



        })



        .filter(item => item.contactId || item.messages.length)



        .sort((a, b) => Number(b.updatedAt || 0) - Number(a.updatedAt || 0));



}



