        'The three age labels must be 楠炲吋妞? 楠炴潙鐨弮? 婵″倷绮?'



    ].join('\n');



    const response = await fetch(buildPrivateContactChatEndpoint(endpoint), {



        method: 'POST',



        headers,



        body: JSON.stringify({



            model,



            temperature: typeof chat.temperature === 'number' ? chat.temperature : 0.7,



            messages: [



                {



                    role: 'system',



                    content: 'Generate one strict JSON object for a private contact profile bundle. The object must include exact type and id values from the user prompt. Do not output markdown, code fences, prose, aliases, or extra wrapper objects.'



                },



