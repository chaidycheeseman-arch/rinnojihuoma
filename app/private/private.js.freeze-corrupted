function normalizePrivateContactProfileStages(value) {



    const labels = getPrivateContactProfileStageLabels();



    const source = Array.isArray(value)



        ? value



        : typeof value === 'string'



            ? value



                .replace(/\r/g, '')



                .split(/\n{2,}/)



                .map((content, index) => ({



                    label: labels[index] || '',



                    content



                }))



        : value && typeof value === 'object'



            ? Object.entries(value).map(([label, content]) => ({ label, content }))



            : [];



    return labels.map((label, index) => {



        const matched = source.find(item => {



            if (typeof item === 'string') return false;



            const raw = String(



                item?.label



                || item?.age



                || item?.stage



                || item?.period



                || item?.['']



                || item?.['']



                || ''



            ).trim();



            if (!raw) return false;



            if (raw === label) return true;



            if (label === '骞兼椂') return /(骞兼椂|绔ュ勾|child)/i.test(raw);



